# Database Configuration
DB_DRIVER=postgres
# Unified DB (LMS + CBT in one PostgreSQL database)
# IMPORTANT: CBT search_path must prioritize cbt schema
DB_DSN=postgres://postgres:root@localhost:5432/intelectodb?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=25
DB_MIN_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MINUTES=5

# Logging Configuration
LOG_LEVEL=-1
LOG_DIRECTORY=

# Server Ports
REST_PORT=8080
GRPC_PORT=6001

# JWT Configuration (MUST MATCH LMS)
JWT_ACCESS_SECRET=your-access-secret-key-change-this-in-production
JWT_ACCESS_TTL_MINUTES=120
JWT_REFRESH_TTL_MINUTES=240

# LMS SSO Token Validation
LMS_JWT_SECRET=your-access-secret-key-change-this-in-production
LMS_JWT_ISSUER=lms-erlangga

# Redis Configuration (deprecated in unified DB mode; kept for backward compatibility)
REDIS_ADDR=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Elastic APM Configuration
ELASTIC_APM_SERVER_URL=http://localhost:8200
ELASTIC_APM_SERVICE_NAME=cbt-mini-project
ELASTIC_APM_SERVICE_VERSION=1.0.0
ELASTIC_APM_ENVIRONMENT=development
ELASTIC_APM_ENABLED=true

# Rate Limit Configuration
RATE_LIMIT_API_REQUESTS_PER_HOUR=1000
RATE_LIMIT_API_REQUESTS_PER_DAY=10000
RATE_LIMIT_TEST_SESSIONS_PER_DAY=10
RATE_LIMIT_TEST_SESSIONS_PER_WEEK=50
RATE_LIMIT_QUESTIONS_PER_DAY=100

# CORS Configuration
CORS_ALLOW_ORIGIN=http://localhost:3000

# Cloudinary Configuration
cloudinary_name=
cloudinary_key=
cloudinary_secret=

IDCODEC_ALPHABET=9wKmP2vLnQ8rXdF5jH0bG7zA3eY6tN4uC1sWoMpRkTxBfIhJEV
